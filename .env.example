# ──────────────────────────────────────────────────
# LILA Lab — Environment Variables
# Copy to .env and fill in your values.
#   cp .env.example .env
# ──────────────────────────────────────────────────

# ── LLM API Keys (for annotation pipelines) ──────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...

# ── GitHub (for registry, issues, CI) ─────────────
GITHUB_TOKEN=ghp_...

# ── Discord Bot (infrastructure/discord-bot/) ─────
DISCORD_TOKEN=...
GUILD_ID=...
